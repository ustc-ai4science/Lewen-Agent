### Database
# Frontend API base URL exposed to the client.
VITE_API_BASE_URL=/api
# Paper search service base URL.
PAPER_SEARCH_V2_BASE_URL="your_paper_search_base_url"
# API key for the paper search service.
PAPER_SEARCH_V2_API_KEY="your_lewen_api_key"

### Agent
# API key used by the paper agent model service.
PAPER_AGENT_V2_API_KEY="your_agent_api_key"
# Model name used by the paper agent.
PAPER_AGENT_V2_MODEL_NAME="your_agent_model_name"
# One or more paper agent service URLs, separated by spaces.
PAPER_AGENT_V2_AGENT_URLS="your_agent_api_url"
# Display names for the paper agent services, separated by spaces.
PAPER_AGENT_V2_AGENT_NAMES="your_agent_name"
# File path for the round log output.
PAPER_AGENT_V2_ROUND_LOG_PATH=logs/agent_rounds.log


# One or more scorer service URLs, separated by spaces.
PAPER_AGENT_V2_SCORER_URLS="your_scorer_url"
# Display names for the scorer services, separated by spaces.
PAPER_AGENT_V2_SCORER_NAMES="your_scorer_name"